# ─────────────────────────────────────────────────────────────────────────────
# Lustra frontend — PRODUCTION (Vercel)
#
# ⚠️  PREPARED, NOT APPLIED. Do not configure Production until UAT has passed
#     its acceptance smoke test AND the owner has explicitly approved it.
#
# Set in Vercel: Project → Settings → Environment Variables, Production scope.
#
# EVERY VITE_* VALUE IS COMPILED INTO THE PUBLIC BROWSER BUNDLE and is readable
# by anyone who loads the site. No secret belongs here.
# ─────────────────────────────────────────────────────────────────────────────

VITE_DATA_MODE=api

# Must include /api/v1 and must be https.
VITE_API_BASE_URL=https://api.lustra.vip/api/v1

# Hub ORIGIN only, no /api/v1.
VITE_SIGNALR_BASE_URL=https://api.lustra.vip

VITE_APP_ENV=production

# Force-disabled in production builds regardless of this value. Set false
# explicitly so the intent is on the record.
VITE_ENABLE_DEV_ROLE_SWITCHER=false

VITE_ENABLE_QUERY_DEVTOOLS=false

# ── Before go-live ───────────────────────────────────────────────────────────
# No UAT value may appear above. In particular VITE_API_BASE_URL must not point
# at uatapi.lustra.vip: the production frontend would then be reading and
# writing UAT data, and CORS would reject it — presenting as a total outage.

# Google Places (address autocomplete). The key is public (it ships in the bundle) —
# restrict it in Google Cloud by HTTP referrer and to Places + Maps JS only.
# Supply the real key via the Vercel environment; never commit it.
VITE_GOOGLE_MAPS_API_KEY=
VITE_GOOGLE_PLACES_COUNTRIES=za
