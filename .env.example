# ─────────────────────────────────────────────────────────────────────────────
# Lustra frontend environment. Copy to `.env.local` for local development, and
# set the same NAMES in the Vercel dashboard (Preview + Production scopes).
#
# EVERY `VITE_*` VALUE IS COMPILED INTO THE PUBLIC BROWSER BUNDLE.
# Never put R2/S3 credentials, JWT signing keys, private bucket names, database
# connection strings or any API secret here. Authorization is enforced by the
# .NET API, never by these values.
#
# src/config/env.ts validates all of this at startup and throws a clear error
# when something required is missing. There is NO silent fallback from api→mock.
# ─────────────────────────────────────────────────────────────────────────────

# ── Data mode ────────────────────────────────────────────────────────────────
# mock | api
#   mock — local development against in-repo fixtures. NOT allowed in a
#          production build: the app renders a "Configuration error" screen.
#   api  — talks to the real .NET API. Requires VITE_API_BASE_URL.
VITE_DATA_MODE=mock

# ── API base URL (REQUIRED when VITE_DATA_MODE=api) ──────────────────────────
# Must include the /api/v1 suffix and MUST be https:// for any deployed
# frontend (a https page cannot call http — the browser blocks mixed content).
# Local dev example:
VITE_API_BASE_URL=https://localhost:7266/api/v1
# Deployed example (replace with the real deployed API host once it exists):
# VITE_API_BASE_URL=https://api.lustra.vip/api/v1

# ── SignalR hub origin (optional) ────────────────────────────────────────────
# Origin only, no /api/v1. Defaults to the API origin when unset.
VITE_SIGNALR_BASE_URL=https://localhost:7266
# Deployed example:
# VITE_SIGNALR_BASE_URL=https://api.lustra.vip

# ── Deployment environment marker ────────────────────────────────────────────
# development | uat | production
VITE_APP_ENV=development

# ── Development role preview (NEVER enable in production) ────────────────────
# Force-disabled in production builds regardless of this flag, and it never
# grants real server permissions — the API remains the authorization boundary.
VITE_ENABLE_DEV_ROLE_SWITCHER=true

# ── React Query devtools (development only) ──────────────────────────────────
VITE_ENABLE_QUERY_DEVTOOLS=false

# ── Public media base URL ────────────────────────────────────────────────────
# Not used today: the API returns absolute, access-checked media URLs and VIP
# media is authorized per request. Do NOT introduce a public media base URL for
# private or VIP media — that would move an authorization decision into the
# browser bundle.

# ── Google Places (address autocomplete) ─────────────────────────────────────
# The Maps JavaScript API key (Places). Public by nature — it ships in the
# bundle — so restrict it in Google Cloud by HTTP referrer and to the Places +
# Maps JS APIs only. Supply the REAL key via .env.local / Vercel, never here.
VITE_GOOGLE_MAPS_API_KEY=
# Comma-separated ISO country codes the autocomplete is restricted to.
VITE_GOOGLE_PLACES_COUNTRIES=za
