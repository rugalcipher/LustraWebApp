#env
# Ignore every env file by default, so a developer's local secrets and any
# ad-hoc .env.<something> can never be committed by accident.
.env
.env.*

# ...but three files ARE committed, and must be.
#
# .env.example      documents every variable the app reads, with no values.
# .env.uat          the UAT fallback, loaded by `vite build --mode uat`.
# .env.production   the LIVE fallback, loaded by a default `vite build`.
#
# Committing the last two is safe BECAUSE every VITE_* value is compiled into
# the public browser bundle: they are already readable by any visitor, so they
# are configuration rather than secrets. Never put a key, token or connection
# string in them — authorization is the API's job, never the bundle's.
!.env.example
!.env.uat
!.env.production

# .env.local stays ignored deliberately. It is a developer's personal override
# and is the one file likely to hold a real credential or a tunnel URL.

# Logs
/logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

.env
.vite
base44/.app.jsonc

# Vercel local project metadata (contains the linked project/org ids)
.vercel

# Ad-hoc scratch scripts at the repo root (one-off Playwright checks and the
# like). Real tests belong in tests/; anything left loose here is disposable.
/*.cjs
/*.mjs

# Test / Playwright artifacts
/test-results
/playwright-report
/screenshots
/blob-report
/.playwright
