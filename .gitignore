#env
.env
.env.*
# ...but the template must be committed: it documents every variable the app
# reads and carries no values. Without it a new developer cannot configure a
# local build, and the deployment contract in ENVIRONMENT.md has no counterpart.
!.env.example

# Logs
/logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

.env
.vite
base44/.app.jsonc

# Vercel local project metadata (contains the linked project/org ids)
.vercel

# Ad-hoc scratch scripts at the repo root (one-off Playwright checks and the
# like). Real tests belong in tests/; anything left loose here is disposable.
/*.cjs
/*.mjs

# Test / Playwright artifacts
/test-results
/playwright-report
/screenshots
/blob-report
/.playwright
